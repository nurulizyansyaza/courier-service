# Homelab staging environment configuration (non-secret values only)
# Secrets (HOMELAB_SSH_KEY, HOMELAB_USER, HOMELAB_HOST) must be set in
# GitHub repository secrets, NOT in this file.

HOMELAB_HOST=nurulizyansyaza.com
HOMELAB_USER=deploy
HOMELAB_DEPLOY_PATH=/opt/courier-service
HOMELAB_DOMAIN=nurulizyansyaza.com
PROJECT_BASE_PATH=/staging/courier-service

ENVIRONMENT=staging

# Docker (staging uses the same compose file, different container)
COMPOSE_FILE=docker-compose.prod.yml
API_CONTAINER=courier-api-staging
API_PORT=3001

# Default active framework
ACTIVE_FRAMEWORK=react
