# Production environment configuration (non-secret values only)
# Secrets (AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY) must be set in
# GitHub repository secrets, NOT in this file.

AWS_REGION=ap-southeast-1
FRONTEND_REGION=us-east-1
ENVIRONMENT=production

# Stack names
FRONTEND_STACK_NAME=courier-frontend-production
API_STACK_NAME=courier-api-production

# Default active framework
ACTIVE_FRAMEWORK=react
